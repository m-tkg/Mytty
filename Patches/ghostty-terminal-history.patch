+    /// Read arbitrary surface text as replayable VT output. This preserves
+    /// colors and character attributes in addition to the textual content.
+    export fn ghostty_surface_read_text_vt(
+        surface: *Surface,
+        sel: Selection,
+        result: *Text,
+    ) bool {
+        surface.core_surface.renderer_state.mutex.lock();
+        defer surface.core_surface.renderer_state.mutex.unlock();
+
+        const core_sel = sel.core(
+            surface.core_surface.renderer_state.terminal.screens.active,
+        ) orelse return false;
+        const terminal_ptr = &surface.core_surface.io.terminal;
+
+        var buf: std.Io.Writer.Allocating = .init(global.alloc);
+        defer buf.deinit();
+        var formatter: terminal.formatter.TerminalFormatter = .init(
+            terminal_ptr,
+            .{
+                .emit = .vt,
+                .unwrap = false,
+                .trim = false,
+            },
+        );
+        formatter.content = .{ .selection = core_sel };
+        formatter.extra = .styles;
+        // Injecting a full OSC 4 palette redefinition into an
+        // already-running surface (as opposed to a freshly created one at
+        // app launch) reliably corrupts the replay: the terminal ends up
+        // showing only the shell's fresh prompt with none of the replayed
+        // lines. Per-cell SGR/hyperlink styling (screen.style/hyperlink,
+        // still enabled via `.styles` above) is unaffected and gives
+        // faithful color reproduction against the surface's current
+        // palette, so we skip only the standalone palette dump.
+        formatter.extra.palette = false;
+        formatter.format(&buf.writer) catch |err| {
+            log.warn("error reading VT text err={}", .{err});
+            return false;
+        };
+        const text = buf.toOwnedSliceSentinel(0) catch |err| {
+            log.warn("error allocating VT text err={}", .{err});
+            return false;
+        };
+
+        result.* = .{
+            .tl_px_x = -1,
+            .tl_px_y = -1,
+            .offset_start = 0,
+            .offset_len = 0,
+            .text = text.ptr,
+            .text_len = text.len,
+        };
+        return true;
+    }
+
     fn readTextLocked(
         surface: *Surface,
         core_sel: terminal.Selection,
@@ -1681,6 +1737,25 @@ pub const CAPI = struct {
         ptr.deinit();
     }
 
+    /// Replay trusted VT output directly into the terminal parser. This is
+    /// output injection, not keyboard input, so it does not reach the shell.
+    export fn ghostty_surface_write_text(
+        surface: *Surface,
+        ptr: [*]const u8,
+        len: usize,
+    ) bool {
+        const io = &surface.core_surface.io;
+        const copy = io.alloc.dupe(u8, ptr[0..len]) catch |err| {
+            log.warn("error allocating VT replay text err={}", .{err});
+            return false;
+        };
+        io.queueMessage(.{ .inject_output = .{
+            .ptr = copy.ptr,
+            .len = copy.len,
+        } }, .unlocked);
+        return true;
+    }
